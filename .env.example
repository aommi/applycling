# Copy this file to .env and fill in the keys for the providers you want to use.
# .env is gitignored — never commit it.
#
# ── applycling pipeline (resume generation) ───────────────────────────
# The pipeline generates resumes, cover letters, and PDFs.
# At least one of these is required.

# Anthropic (Claude models) — recommended, best quality
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, o-series)
OPENAI_API_KEY=sk-...

# Google AI Studio (Gemini)
GOOGLE_API_KEY=...

# Ollama (local models, no API key needed)
# Set provider to "ollama" in data/config.json and model to e.g. "llama3.1:latest"

# ── Hermes Telegram gateway (message routing) ─────────────────────────
# If using the optional Hermes Telegram gateway for inbound job URL intake,
# the Hermes profile needs its own API key. The setup script copies this
# from ~/.hermes/.env automatically. See scripts/setup_hermes_telegram.sh.
#
# Hermes needs a key for whatever provider you configure in the profile
# (default: deepseek-v4-pro → DEEPSEEK_API_KEY).
# Set this in ~/.hermes/.env, not here.
