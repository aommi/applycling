# applycling hosted deployment — copy to /opt/applycling/.env and fill in
APPLYCLING_DB_BACKEND=postgres
POSTGRES_PASSWORD=***GENERATE: openssl rand -base64 24***
DATABASE_URL=postgresql://applycling:***SAME AS POSTGRES_PASSWORD***@postgres:5432/applycling
ANTHROPIC_API_KEY=***FROM YOUR LOCAL .env***
APPLYCLING_UI_AUTH_USER=***PICK A USERNAME***
APPLYCLING_UI_AUTH_PASSWORD=***GENERATE: openssl rand -base64 24***
APPLYCLING_INTAKE_SECRET=***GENERATE: openssl rand -base64 24***
APPLYCLING_STALE_RUN_TIMEOUT_MINUTES=120
