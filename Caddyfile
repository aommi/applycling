# REPLACE the hostname below with your actual domain before first deploy.
# Caddy will attempt to issue a Let's Encrypt certificate for whatever hostname
# is listed here — "your-domain.com" will fail TLS issuance.
# ═══════════════════════════════════════════════════════════════════════════════

your-domain.com {
    # Enable automatic HTTPS via Let's Encrypt
    # Caddy auto-issues and auto-renews certificates

    # Reverse proxy to the applycling workbench
    reverse_proxy applycling:8080

    # Log format for docker logs
    log {
        output stdout
    }
}
