# Note: for the Caddy Docker container, this file should be mounted to /etc/caddy/Caddyfile
# This is handled automatically in docker-compose.prod.yml.
#
# Two sites:
#   applycling.com (+ www) → static landing page from /srv/landing
#   app.applycling.com     → reverse proxy to the workbench

applycling.com, www.applycling.com {
    root * /srv/landing
    file_server
    encode gzip zstd

    log {
        output stdout
    }
}

app.applycling.com {
    reverse_proxy applycling:8080

    log {
        output stdout
    }
}
