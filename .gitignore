# Virtual environments
.venv/
venv/
env/

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
*.egg
build/
dist/
.eggs/

# Secrets
.env

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Personal data — never commit your resume or tailored outputs
data/*
!data/.gitkeep
output/*
!output/.gitkeep

# Local Claude Code tooling — track settings.json (hooks), ignore everything else
.claude/worktrees/
.claude/projects/
.claude/agent-memory/
.claude/settings.local.json

# Other agent configs — track entry-point files, ignore IDE-specific state
.cursor/history/
.gemini/history/

# Antigravity — fully generated by .agent/generate.py antigravity
.agents/

# Agent memory kit generation state — ephemeral, auto-regenerated
.agent/.generated_state.json

# Stray screenshots / image dumps — commit images explicitly under docs/ if intended
images/
.agent/.last_checked_commit

# Local planning notes
docs/planning/
TOREVIEW/
memory/working.md

# Disabled agent outputs
.cursor/
.cursorignore (generated by generate.py all --force)
.gemini/
.openclaw-system.md
.windsurfrules
GEMINI.md
.agent/memory-kit/tests/
