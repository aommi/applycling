# Virtual environments
.venv/
venv/
env/

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# Secrets
.env

# Editor / OS
.DS_Store
.vscode/
